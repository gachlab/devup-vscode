{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "watch",
      "type": "npm",
      "script": "watch",
      "isBackground": true,
      "presentation": {
        "reveal": "never",
        "panel": "dedicated"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        {
          "owner": "esbuild",
          "fileLocation": "absolute",
          "pattern": [
            {
              "regexp": "^(.+):(\\d+):(\\d+): ERROR: (.+)$",
              "file": 1, "line": 2, "column": 3, "message": 4
            }
          ],
          "background": {
            "activeOnStart": true,
            "beginsPattern": "\\[watch\\]",
            "endsPattern": "\\[build finished\\]"
          }
        }
      ]
    }
  ]
}
